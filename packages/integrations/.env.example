# Per-school integration env — EACH school sets its OWN project values.
# Client (Vite) vars are VITE_-prefixed; server vars are not exposed to the browser.
# Nothing here is shared between tenants; only the Supabase DB is shared.

# PostHog (product analytics) — this school's project
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Microsoft Clarity (session replay) — this school's project id
VITE_CLARITY_ID=xxxxxxxxxx

# Firebase (this school's OWN Firebase project) — web push + messaging
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# Upstash Redis (server only) — this school's database
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# QStash (server only) — this school's token
QSTASH_TOKEN=

# Shared (same for all schools — the one Supabase project)
VITE_SUPABASE_URL=https://xwgtsldimlrhtgvpnjnd.supabase.co
VITE_SUPABASE_ANON_KEY=
