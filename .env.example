# Supabase (get from: supabase.com → your project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xwgtsldimlrhtgvpnjnd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI
ANTHROPIC_API_KEY=your-anthropic-key
# GEMINI_API_KEY — set as Supabase edge function secret, not needed here

# Firebase Cloud Messaging (FCM)
# Firebase Console → Project Settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Key pair
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Africa's Talking (SMS + GPS flow)
AT_API_KEY=your-at-api-key
AT_USERNAME=your-at-username
AT_SENDER_ID=NKOROI
AT_WEBHOOK_SECRET=random-secret-for-signature-verification

# QR Code signing
SYCHAR_QR_SECRET=generate-with-openssl-rand-hex-32

# App URLs
APP_URL=https://sychar-copilot-pwa.vercel.app
