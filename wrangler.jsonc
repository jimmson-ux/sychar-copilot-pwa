{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "sychar-system",
  "compatibility_date": "2026-04-29",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "sychar-system"
    }
  ],
  "images": {
    "binding": "IMAGES"
  },
  "observability": {
    "enabled": true
  },

  // ── Non-secret runtime vars (safe to commit) ──────────────────────────────
  "vars": {
    "NEXT_PUBLIC_SUPABASE_URL": "https://xwgtsldimlrhtgvpnjnd.supabase.co",
    "UPSTASH_REDIS_REST_URL": "https://on-tomcat-78669.upstash.io"
  },

  // ── Secrets — set via: npx wrangler secret put <NAME> ────────────────────
  // Required secrets (never commit values):
  //   SUPABASE_SERVICE_ROLE_KEY
  //   NEXT_PUBLIC_SUPABASE_ANON_KEY
  //   UPSTASH_REDIS_REST_TOKEN
  //   RESEND_API_KEY
  //   TRIGGER_API_KEY
  //   NEXT_PUBLIC_POSTHOG_KEY      (build-time only — set before npm run build)
  //   NEXT_PUBLIC_CLARITY_ID       (build-time only — set before npm run build)
  //   NEXT_PUBLIC_FORMBRICKS_WORKSPACE_ID  (build-time only)

  "routes": [
    { "pattern": "sychar.co.ke/*",   "zone_name": "sychar.co.ke" },
    { "pattern": "*.sychar.co.ke/*", "zone_name": "sychar.co.ke" }
  ]
}
